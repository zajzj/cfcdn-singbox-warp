{
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "wireguard",
      "tag": "warp",
      "server": "127.0.0.1",
      "server_port": 2408,
      "local_address": ["172.16.0.2/32"],
      "private_key": "你的WARP私钥",
      "peer_public_key": "WARP公钥",
      "reserved": [0, 0, 0],
      "mtu": 1280
    }
  ],
  "route": {
    "rules": [
      {
        "domain_suffix": ["openai.com", "ai.com", "anthropic.com", "google.com"],
        "outbound": "warp"
      }
    ]
  }
}
